{
  "name": "polymarket-tail-risk",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "bootstrap": "powershell -ExecutionPolicy Bypass -File ./scripts/bootstrap.ps1",
    "dev": "concurrently -n web,api,worker,beat -c blue,green,magenta,yellow \"npm run dev:web\" \"npm run dev:api\" \"npm run dev:worker\" \"npm run dev:beat\"",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "python -m uvicorn app.main:app --reload --app-dir apps/api --host 0.0.0.0 --port 8000",
    "dev:worker": "powershell -Command \"$env:PYTHONPATH='workers;apps/api'; .\\.venv\\Scripts\\celery.exe -A worker.celery_app:celery_app worker --loglevel INFO --pool solo\"",
    "dev:beat": "powershell -Command \"$env:PYTHONPATH='workers;apps/api'; .\\.venv\\Scripts\\celery.exe -A worker.celery_app:celery_app beat --loglevel INFO\"",
    "task:market-sync": "powershell -Command \"$env:PYTHONPATH='workers;apps/api'; .\\.venv\\Scripts\\celery.exe -A worker.celery_app:celery_app call worker.ingest.dispatch_market_sync\"",
    "task:snapshot-sync": "powershell -Command \"$env:PYTHONPATH='workers;apps/api'; .\\.venv\\Scripts\\celery.exe -A worker.celery_app:celery_app call worker.ingest.dispatch_snapshot_capture\"",
    "task:dq-run": "powershell -Command \"$env:PYTHONPATH='workers;apps/api'; .\\.venv\\Scripts\\celery.exe -A worker.celery_app:celery_app call worker.dq.dispatch_market_dq_scan\"",
    "task:tagging-run": "powershell -Command \"$env:PYTHONPATH='workers;apps/api'; .\\.venv\\Scripts\\celery.exe -A worker.celery_app:celery_app call worker.tagging.dispatch_market_auto_classification\"",
    "db:upgrade": ".\\.venv\\Scripts\\python.exe -m alembic -c apps/api/alembic.ini upgrade head",
    "db:downgrade": ".\\.venv\\Scripts\\python.exe -m alembic -c apps/api/alembic.ini downgrade base",
    "db:current": ".\\.venv\\Scripts\\python.exe -m alembic -c apps/api/alembic.ini current",
    "dev:prepare": "npm run db:upgrade"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
